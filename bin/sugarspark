#!/usr/bin/env php
<?php

declare(strict_types=1);

use SugarCraft\Spark\Inspector;
use SugarCraft\Spark\Lang;

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',     // dev: standalone
    __DIR__ . '/../../../autoload.php',      // installed under vendor/bin
    __DIR__ . '/../../vendor/autoload.php',  // monorepo dev
];
foreach ($autoloadCandidates as $autoload) {
    if (file_exists($autoload)) {
        require $autoload;
        break;
    }
}

$input = '';
if (!empty($argv[1])) {
    // Reject stream wrappers (php://, data://, http://, …) — a file-path argument
    // must not be coerced into fetching a URL or evaluating a wrapper. is_file()
    // is false for every wrapper scheme and for non-existent paths. The '@' is
    // dropped so a genuine read error (e.g. unreadable file) surfaces as a warning.
    if (!is_file($argv[1])) {
        fwrite(STDERR, Lang::t('cli.not_a_file', ['path' => (string) $argv[1]]) . "\n");
        exit(1);
    }
    $input = (string) file_get_contents($argv[1]);
} elseif (!stream_isatty(STDIN)) {
    $input = (string) stream_get_contents(STDIN);
}

if ($input === '') {
    fwrite(STDERR, Lang::t('cli.usage') . "\n");
    exit(1);
}

echo Inspector::report($input), PHP_EOL;
