{
    "name": "candycore/sugar-spark",
    "description": "PHP port of charmbracelet/sequin — ANSI escape-sequence inspector. Decodes SGR / CSI / OSC / DCS / APC / SS3 sequences into human-readable labels.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ansi", "escape", "inspector", "debug",
        "sequin", "tui", "terminal",
        "candycore"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-spark",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-spark/issues",
        "source": "https://github.com/sugarcraft/sugar-spark",
        "docs":   "https://sugarcraft.github.io/lib/sugar-spark.html"
    },
    "bin": ["bin/sugarspark"],
    "require": {
        "php": "^8.1",
        "candycore/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Spark\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Spark\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
