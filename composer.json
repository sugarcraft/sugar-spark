{
    "name": "candycore/sugar-spark",
    "description": "PHP port of charmbracelet/sequin — ANSI escape-sequence inspector for CandyCore.",
    "type": "library",
    "license": "MIT",
    "bin": ["bin/sugarspark"],
    "require": {
        "php": "^8.1",
        "candycore/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core", "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Spark\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Spark\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
